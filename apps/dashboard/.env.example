# ─── Clerk (Auth) ─────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → Create application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# URLs de redirection Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chimera
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chimera

# ─── Queen Node.js (backend) ──────────────────────────────────────────────────
# En développement : http://localhost:3000
# En production sur Railway : https://chimera-queen.railway.app
NEXT_PUBLIC_QUEEN_URL=http://localhost:3000

# WebSocket Queen
# En développement : ws://localhost:9002
# En production : wss://chimera-queen.railway.app/ws  (si Railway + proxy WS)
NEXT_PUBLIC_DASHBOARD_WS_URL=ws://localhost:9002

# ─── Optionnel : Analytics ────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
