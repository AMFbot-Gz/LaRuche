{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@saas/ui-kit": [
        "../../libs/ui-kit/src/index.ts"
      ],
      "@saas/ui-kit/*": [
        "../../libs/ui-kit/src/*"
      ],
      "@saas/common": [
        "../../libs/common/src/index.ts"
      ],
      "@saas/common/*": [
        "../../libs/common/src/*"
      ]
    },
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
