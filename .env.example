# ════════════════════════════════════════════════════════
# 🐝 LaRuche .env — Copy to .env and fill in REQUIRED fields
# ════════════════════════════════════════════════════════

# ══════════════════════════════════════════════
# REQUIRED — Bot won't start without these
# ══════════════════════════════════════════════

TELEGRAM_BOT_TOKEN=                # From @BotFather → /newbot
ADMIN_TELEGRAM_ID=                 # From @userinfobot → send /start

# ══════════════════════════════════════════════
# OLLAMA — Local LLM (default: auto-detect)
# ══════════════════════════════════════════════

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b           # Default worker model

# Auto-detection per role (leave blank for auto)
OLLAMA_MODEL_STRATEGIST=           # e.g. glm-4.6:cloud
OLLAMA_MODEL_ARCHITECT=            # e.g. qwen3-coder:32b
OLLAMA_MODEL_WORKER=               # e.g. llama3.2:3b
OLLAMA_MODEL_VISION=               # e.g. llava:7b

# ══════════════════════════════════════════════
# PERFORMANCE — LaRuche run mode
# ══════════════════════════════════════════════

LARUCHE_MODE=balanced              # low | balanced | high
NODE_ENV=production
LOG_LEVEL=info                     # error | warn | info | debug
WORKSPACE_ROOT=                    # auto-set by fast_install.sh

# ══════════════════════════════════════════════
# OPTIONAL — Cloud LLM providers
# Disabled by default. Set *_ENABLED=true to activate.
# ══════════════════════════════════════════════

ANTHROPIC_API_KEY=
ANTHROPIC_ENABLED=false

OPENAI_API_KEY=
OPENAI_ENABLED=false

KIMI_API_KEY=
KIMI_ENABLED=false

OPENROUTER_API_KEY=
OPENROUTER_ENABLED=false

# ══════════════════════════════════════════════
# OPTIONAL — Advanced settings
# ══════════════════════════════════════════════

COST_ALERT_USD=2.00                # Alert if mission costs > $2
HITL_TIMEOUT_SEC=60                # Auto-reject HITL after 60s
RAM_LIMIT_MB=500                   # PM2 restart threshold
