# ============================================================
# PROJECT CHIMERA — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# === SÉCURITÉ (OBLIGATOIRE) ===
# Génère avec : openssl rand -hex 32
# CRITIQUE : Ne jamais utiliser cette valeur en production
CHIMERA_SECRET=CHANGE_ME_openssl_rand_hex_32
NODE_ENV=development

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_DEFAULT=llama3.2:3b
OLLAMA_MODEL_CODE=qwen3-coder
OLLAMA_MODEL_VISION=llava

# === GATEWAY TELEGRAM (optionnel) ===
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=
STANDALONE_MODE=true

# === PORTS (Queen Node.js) ===
QUEEN_PORT=3000
HUD_PORT=9001

# === PORTS (Python Agents) ===
AGENT_ORCHESTRATION_PORT=8001
AGENT_PERCEPTION_PORT=8002
AGENT_BRAIN_PORT=8003
AGENT_EXECUTOR_PORT=8004
AGENT_EVOLUTION_PORT=8005
AGENT_MEMORY_PORT=8006
AGENT_MCP_BRIDGE_PORT=8007

# === AGENT URLS (internal service discovery) ===
# Used by agents to call each other — change if running in Docker/K8s
AGENT_BRAIN_URL=http://localhost:8003
AGENT_MEMORY_URL=http://localhost:8006

# === BRAIN AGENT ===
# auto | local_only | claude_only
ROUTING_MODE=auto
# Override the Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# === DASHBOARD ===
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
DASHBOARD_PORT=3001
DASHBOARD_WS_PORT=9002
# Génère avec : openssl rand -hex 24
# Laisser vide = dashboard accessible sans auth (DEV uniquement)
DASHBOARD_TOKEN=CHANGE_ME_openssl_rand_hex_24
NEXT_PUBLIC_DASHBOARD_WS_URL=ws://localhost:9002

# === GATEWAY MULTI-CANAUX ===
GATEWAY_PORT=8100
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
WHATSAPP_SESSION=

# === MÉMOIRE ===
CHROMADB_PATH=./agents/memory/data/vector_store
EPISODES_MAX=1000
VAULT_DIR=./agents/memory/data/vault

# === GITHUB (pour auto-commit évolution) ===
GITHUB_TOKEN=
GITHUB_REPO=AMFbot-Gz/chimera

# === MONITORING ===
SLACK_WEBHOOK=
