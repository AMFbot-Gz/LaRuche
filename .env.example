# ╔════════════════════════════════════════════════════════
# 🐝 LaRuche .env v4.1 — Copy to .env and fill in REQUIRED fields
# ╚════════════════════════════════════════════════════════

# ══════════════════════════════════════════════
# REQUIRED — Bot won't start without these
# ══════════════════════════════════════════════

TELEGRAM_BOT_TOKEN=                # From @BotFather → /newbot
ADMIN_TELEGRAM_ID=                 # From @userinfobot → send /start

# ══════════════════════════════════════════════
# OLLAMA — Local LLM (défaut: auto-detect)
# ══════════════════════════════════════════════

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b           # Modèle worker par défaut

# Auto-détection par rôle (laisser vide pour auto)
OLLAMA_MODEL_STRATEGIST=           # ex: glm-4.6:cloud
OLLAMA_MODEL_ARCHITECT=            # ex: qwen3-coder:32b
OLLAMA_MODEL_WORKER=               # ex: llama3.2:3b
OLLAMA_MODEL_VISION=               # ex: llava:7b

# ══════════════════════════════════════════════
# PERFORMANCE
# ══════════════════════════════════════════════

LARUCHE_MODE=balanced              # low | balanced | high
NODE_ENV=production
LOG_LEVEL=info                     # error | warn | info | debug
LOG_MAX_SIZE_MB=10                 # Taille max d'un fichier de log avant rotation
WORKSPACE_ROOT=                    # auto-set by fast_install.sh

# ══════════════════════════════════════════════
# SKILLS
# ══════════════════════════════════════════════

SKILLS_MODE=dynamic                # dynamic | builtin-only

# ══════════════════════════════════════════════
# OPTIONAL — Cloud LLM providers
# Désactivés par défaut. Mettre *_ENABLED=true pour activer.
# ══════════════════════════════════════════════

ANTHROPIC_API_KEY=
ANTHROPIC_ENABLED=false

OPENAI_API_KEY=
OPENAI_ENABLED=false

KIMI_API_KEY=
KIMI_ENABLED=false

OPENROUTER_API_KEY=
OPENROUTER_ENABLED=false

# ══════════════════════════════════════════════
# ADVANCED
# ══════════════════════════════════════════════

COST_ALERT_USD=2.00                # Alerte si la mission coûte > $2
HITL_TIMEOUT_SEC=60                # Auto-rejet HITL après 60s
HITL_AUTO_APPROVE=false            # true = approuve tout automatiquement (CI)
HITL_AUTO_REJECT=false             # true = rejette tout automatiquement
RAM_LIMIT_MB=500                   # Seuil de restart PM2
LLM_MAX_RETRIES=2                  # Nombre de retries callLLM (exponential backoff)
LLM_BASE_DELAY_MS=1000             # Délai de base entre retries (ms)
ROLLBACK_TTL_DAYS=7               # Durée de conservation des snapshots rollback

# ══════════════════════════════════════════════
# STANDALONE MODE — API REST sans Telegram
# ══════════════════════════════════════════════

STANDALONE_MODE=false              # true → skip Telegram, start REST API
API_PORT=3000                      # Port de l'API REST standalone
CORS_ORIGIN=http://localhost:8080  # Origine CORS autorisée (dashboard)
HUD_PORT=9001                      # Port WebSocket HUD
HUD_TOKEN=                         # Token optionnel pour sécuriser le HUD WS
