# ============================================================
# PROJECT CHIMERA — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
#
# Sections :
#   OBLIGATOIRE  — requis pour démarrer Chimera
#   OPTIONNEL    — fonctionnalités avancées (Telegram, Discord…)
#   AVANCÉ       — tuning fin, chiffrement, monitoring
# ============================================================

# ─────────────────────────────────────────────────────────────
# OBLIGATOIRE
# ─────────────────────────────────────────────────────────────

# === SÉCURITÉ (OBLIGATOIRE) ===
# Génère avec : openssl rand -hex 32
# CRITIQUE : Ne jamais utiliser cette valeur en production
CHIMERA_SECRET=CHANGE_ME_openssl_rand_hex_32
NODE_ENV=development

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_DEFAULT=llama3.2:3b
OLLAMA_MODEL_CODE=qwen3-coder
OLLAMA_MODEL_VISION=llava

# ─────────────────────────────────────────────────────────────
# OPTIONNEL
# ─────────────────────────────────────────────────────────────

# === GATEWAY TELEGRAM (optionnel) ===
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=
STANDALONE_MODE=true

# === PORTS (Queen Node.js) ===
QUEEN_PORT=3000
HUD_PORT=9001

# === PORTS (Python Agents) ===
AGENT_ORCHESTRATION_PORT=8001
AGENT_PERCEPTION_PORT=8002
AGENT_BRAIN_PORT=8003
AGENT_EXECUTOR_PORT=8004
AGENT_EVOLUTION_PORT=8005
AGENT_MEMORY_PORT=8006
AGENT_MCP_BRIDGE_PORT=8007
AGENT_DISCOVERY_PORT=8008
AGENT_KNOWLEDGE_PORT=8009

# === AGENT URLS (internal service discovery) ===
# Utilisées par les agents pour s'appeler entre eux.
# Changez si vous déployez en Docker/K8s (ex: http://brain:8003)
AGENT_ORCHESTRATION_URL=http://localhost:8001
AGENT_PERCEPTION_URL=http://localhost:8002
AGENT_BRAIN_URL=http://localhost:8003
AGENT_EXECUTOR_URL=http://localhost:8004
AGENT_EVOLUTION_URL=http://localhost:8005
AGENT_MEMORY_URL=http://localhost:8006
AGENT_MCP_BRIDGE_URL=http://localhost:8007
AGENT_DISCOVERY_URL=http://localhost:8008
AGENT_KNOWLEDGE_URL=http://localhost:8009

# === BRAIN AGENT ===
# auto | local_only | claude_only
ROUTING_MODE=auto
# Override the Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# === DASHBOARD ===
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
# Dashboard reads agent ports via NEXT_PUBLIC_ prefix (exposed to browser by Next.js)
NEXT_PUBLIC_AGENT_ORCHESTRATION_PORT=8001
NEXT_PUBLIC_AGENT_PERCEPTION_PORT=8002
NEXT_PUBLIC_AGENT_BRAIN_PORT=8003
NEXT_PUBLIC_AGENT_EXECUTOR_PORT=8004
NEXT_PUBLIC_AGENT_EVOLUTION_PORT=8005
NEXT_PUBLIC_AGENT_MEMORY_PORT=8006
NEXT_PUBLIC_AGENT_MCP_BRIDGE_PORT=8007
NEXT_PUBLIC_AGENT_DISCOVERY_PORT=8008
NEXT_PUBLIC_AGENT_KNOWLEDGE_PORT=8009
DASHBOARD_PORT=3001
DASHBOARD_WS_PORT=9002
# Génère avec : openssl rand -hex 24
# Laisser vide = dashboard accessible sans auth (DEV uniquement)
DASHBOARD_TOKEN=CHANGE_ME_openssl_rand_hex_24
NEXT_PUBLIC_DASHBOARD_WS_URL=ws://localhost:9002

# === GATEWAY MULTI-CANAUX ===
GATEWAY_PORT=8100
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
WHATSAPP_SESSION=

# === MÉMOIRE ===
CHROMADB_PATH=./agents/memory/data/vector_store
EPISODES_MAX=1000
VAULT_DIR=./agents/memory/data/vault

# === GITHUB (pour auto-commit évolution) ===
GITHUB_TOKEN=
GITHUB_REPO=AMFbot-Gz/chimera

# === MONITORING ===
SLACK_WEBHOOK=

# === STRIPE BILLING (SaaS) ===
# Clés disponibles sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret de signature webhook — généré dans Stripe Dashboard > Webhooks
# Événements à activer : checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted, invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs créés dans Stripe Dashboard > Products
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAMS_PRICE_ID=price_...
# URL de base de l'application (pour les redirections Stripe)
APP_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────
# AVANCÉ
# ─────────────────────────────────────────────────────────────

# ─── Chiffrement données utilisateur ─────────────────────────────────────────
# Activer le chiffrement AES-256-GCM des données ChromaDB
CHIMERA_ENCRYPTION_ENABLED=false
# Clé maître (si absent: dérivée de HUD_TOKEN, ou générée automatiquement)
# CHIMERA_MASTER_KEY=votre_clé_secrète_ici
